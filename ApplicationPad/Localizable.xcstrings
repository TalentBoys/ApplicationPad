    "This will remove all folders and reset app positions to default alphabetical order." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove all folders and reset app positions to default alphabetical order."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todas las carpetas y restablecerá las posiciones a orden alfabético."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのフォルダを削除し、アプリの位置をデフォルトのアルファベット順にリセットします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将移除所有文件夹并将应用位置重置为默认字母顺序。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將移除所有資料夾並將應用程式位置重置為預設字母順序。"
          }
        }
      }
    },
    "This will remove all folders and reset app positions to default alphabetical order. This action cannot be undone." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
