        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのフォルダを削除し、アプリの位置をデフォルトのアルファベット順にリセットします。この操作は元に戻せません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将移除所有文件夹并将应用位置重置为默认字母顺序。此操作无法撤销。"
